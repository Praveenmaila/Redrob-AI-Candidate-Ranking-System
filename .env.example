# ============================================================================
# Redrob AI Candidate Ranking System – Environment Variables
# ============================================================================
# Copy this file to .env and fill in values for your deployment.

# ── Backend ────────────────────────────────────────────────────────────
# Python unbuffered output (recommended for Docker/production)
PYTHONUNBUFFERED=1

# Port the backend listens on (Render sets $PORT automatically)
PORT=8000

# ── Frontend ───────────────────────────────────────────────────────────
# Backend URL that Next.js rewrites proxy to.
# Local dev:   http://localhost:8000
# Docker:      http://backend:8000
# Production:  https://your-backend.onrender.com
NEXT_PUBLIC_BACKEND_TARGET=http://localhost:8000

# Node environment
NODE_ENV=development
